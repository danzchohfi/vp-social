# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://producao.app
BETTER_AUTH_SECRET=gere-um-segredo-forte-aqui

# Durante migração de domínio (deixe vazio fora de transição).
# Separe por vírgula. Hosts aqui aceitam OAuth callbacks e session cookies
# em paralelo ao NEXT_PUBLIC_APP_URL. Remover após DNS estável + 30d.
# Ex: ADDITIONAL_TRUSTED_ORIGINS=https://posts.vitaminapublicitaria.com.br
ADDITIONAL_TRUSTED_ORIGINS=

# Banco de dados (Neon)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/publify?sslmode=require

# Email (Resend — opcional; sem isso, emails só logam no console em dev)
RESEND_API_KEY=
RESEND_FROM=Produção <contato@producao.app>
# Inbox que recebe leads do formulário /demo (sem isso, default abaixo)
DEMO_LEAD_EMAIL=daniel@vitaminapublicitaria.com.br

# Google OAuth (console.cloud.google.com → APIs → Credentials → OAuth 2.0)
# Habilite "YouTube Data API v3" e adicione escopo youtube.upload nas credenciais
# Redirect URIs: https://producao.app/api/auth/callback/google
#                https://producao.app/api/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# TikTok (developer.tiktok.com → My Apps → Create App → Content Posting API)
# Redirect URI: https://producao.app/api/tiktok/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# LinkedIn (developer.linkedin.com → Create App → Products: Share on LinkedIn)
# Redirect URI: https://producao.app/api/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Meta (Facebook / Instagram)
# Redirect URIs: https://producao.app/api/auth/callback/facebook
#                https://producao.app/api/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Notion OAuth (developers.notion.com → My integrations → Public integration)
# Redirect URI: https://producao.app/api/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Trigger.dev (trigger.dev → criar projeto → copiar Project ID e Secret)
TRIGGER_PROJECT_ID=proj_xxxxxxxxxxxxxxxx
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxxxxxx

# Stories > 60s são fatiadas em chunks via ffmpeg no worker e enviadas direto
# pro Instagram via Resumable Upload API. Não precisa de storage externo
# (Vercel Blob, S3, etc.) — o arquivo local é uploaded direto pra rupload.
# facebook.com e descartado depois.
