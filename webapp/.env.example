# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=gere-um-segredo-forte-aqui

# Banco de dados (Neon)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/publify?sslmode=require

# Google OAuth (console.cloud.google.com → APIs → Credentials → OAuth 2.0)
# Habilite "YouTube Data API v3" e adicione escopo youtube.upload nas credenciais
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# TikTok (developer.tiktok.com → My Apps → Create App → Content Posting API)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# LinkedIn (developer.linkedin.com → Create App → Products: Share on LinkedIn)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Meta (Facebook / Instagram)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Notion OAuth
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Trigger.dev (trigger.dev → criar projeto → copiar Project ID e Secret)
TRIGGER_PROJECT_ID=proj_xxxxxxxxxxxxxxxx
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxxxxxx
